{
  "crons": [
    {
      "path": "/api/cron/daily-goals-reminder",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/deadline-warning",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/overdue-goals",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/inventory-management/daily-report",
      "schedule": "0 23 * * *"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    },
    "api/**/*.ts": {
      "maxDuration": 60
    }
  }
}
